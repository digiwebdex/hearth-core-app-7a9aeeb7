# ═══════════════════════════════════════════════════════════
# Category A Project — .env Template
# Copy to /opt/projects/<name>/.env and fill in values
# Permissions: chmod 600 .env
# ═══════════════════════════════════════════════════════════

# ─── Identity ───
PROJECT_NAME=hearth-core
APP_DOMAIN=app.travelagencyweb.com

# ─── Ports (from vps/templates/docs/PORT_REGISTRY.md) ───
APP_PORT=4101
DB_PORT=5401
REDIS_PORT=6401

# ─── Database ───
DB_USER=hearth
DB_NAME=hearth_db
# Generate: openssl rand -base64 24
DB_PASSWORD=CHANGE_ME_TO_STRONG_RANDOM

# ─── Secrets ───
# Generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING

# ─── External Services (per-project) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=

# ─── Optional ───
# SENTRY_DSN=
# STRIPE_SECRET_KEY=
