# ═══════════════════════════════════════════════════════════
# Category A Project — .env Template
# Copy to /opt/projects/<name>/.env and fill in real values.
# Permissions: chmod 600 .env
# ═══════════════════════════════════════════════════════════

PROJECT_NAME=hearth-core
APP_DOMAIN=app.travelagencyweb.com
API_DOMAIN=api.travelagencyweb.com

APP_PORT=4101
DB_PORT=5401
REDIS_PORT=6401

DB_USER=hearth
DB_NAME=hearth_db
DB_PASSWORD=CHANGE_ME_TO_STRONG_RANDOM
DATABASE_URL=postgresql://hearth:CHANGE_ME_TO_STRONG_RANDOM@db:5432/hearth_db?schema=public

JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING
CRON_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING

FRONTEND_URL=https://app.travelagencyweb.com
API_BASE_URL=https://api.travelagencyweb.com/api
CORS_ORIGIN=https://app.travelagencyweb.com,https://travelagencyweb.com,https://www.travelagencyweb.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=
