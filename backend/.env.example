DATABASE_URL="postgresql://skyline:YOUR_DB_PASSWORD@localhost:5432/skyline_db"
JWT_SECRET="change-this-to-a-random-64-char-string"
PORT=4000
CORS_ORIGIN="https://travelagencyweb.com"
UPLOAD_DIR="/var/www/skyline-backend/uploads"

# SMTP (optional — without these, emails are logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@travelagencyweb.com
SMTP_FROM_NAME=Skyline Travel

# Frontend URL for email links
FRONTEND_URL=https://travelagencyweb.com

# Admin notification email (receives demo/contact form alerts)
ADMIN_NOTIFICATION_EMAIL=

# Cron secret for subscription expiry job
CRON_SECRET=
