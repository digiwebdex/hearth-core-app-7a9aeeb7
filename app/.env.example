# ════════════════════════════════════════════════════════════
# /srv/travelagencyweb/app/.env  (copy to .env, fill values)
# Used by docker-compose.yml — never commit the real .env
# ════════════════════════════════════════════════════════════

# ── Database ──
POSTGRES_DB=travelagencyweb_db
POSTGRES_USER=travelagencyweb_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Auth / API ──
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING
CORS_ORIGIN=https://travelagencyweb.com,https://www.travelagencyweb.com,https://app.travelagencyweb.com,https://portal.travelagencyweb.com

# ── Public URLs ──
VITE_API_URL=https://api.travelagencyweb.com
FRONTEND_URL=https://travelagencyweb.com
API_BASE_URL=https://api.travelagencyweb.com/api
PORTAL_URL=https://portal.travelagencyweb.com
PUBLIC_UPLOAD_URL=https://api.travelagencyweb.com/uploads

# ── Cron ──
CRON_SECRET=CHANGE_ME_RANDOM

# ── SMTP (optional) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@travelagencyweb.com
SMTP_FROM_NAME=Travel Agency Web
ADMIN_NOTIFICATION_EMAIL=
