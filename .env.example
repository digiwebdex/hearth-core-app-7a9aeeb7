# ══════════════════════════════════════════════════════
# Environment Variables — copy to .env.production
# ══════════════════════════════════════════════════════

# Backend API URL (your Express server on the same VPS)
VITE_API_URL=https://api.travelagencyweb.com/api

# App domain for multi-tenant subdomain detection
# Reserved subdomains: app, portal, api, www, admin
#   travelagencyweb.com         → marketing site
#   app.travelagencyweb.com     → agency staff + super admin
#   portal.travelagencyweb.com  → customer / supplier self-service
#   api.travelagencyweb.com     → backend API
#   {slug}.travelagencyweb.com  → agency public website
VITE_APP_DOMAIN=travelagencyweb.com
